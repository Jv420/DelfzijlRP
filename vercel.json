{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/panel.css",
      "destination": "/web/control-panel/panel.css"
    },
    {
      "source": "/panel.js",
      "destination": "/web/control-panel/panel.js"
    },
    {
      "source": "/panel",
      "destination": "/web/control-panel/index.html"
    },
    {
      "source": "/panel/:path*",
      "destination": "/web/control-panel/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "fanta.delfzijlrp.nl"
        }
      ],
      "destination": "/web/control-panel/index.html"
    }
  ]
}
