# =============================================
# Delfzijl RP - ESX Legacy server.cfg.example
# Kopieer dit bestand lokaal naar server.cfg
# Vul echte keys alleen lokaal in, niet in GitHub.
# =============================================

endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"

sv_hostname "Delfzijl RP | ESX Legacy | Nederland RP"
sets sv_projectName "Delfzijl RP"
sets sv_projectDesc "Nederlandse roleplayserver met eigen Delfzijl-systemen"
sets locale "nl-NL"

sv_maxclients 32
set onesync on
set sv_enforceGameBuild 3095

sv_licenseKey "VUL_HIER_JE_FIVEM_LICENSE_KEY_IN"
set steam_webApiKey "VUL_HIER_JE_STEAM_WEB_API_KEY_IN"
set mysql_connection_string "mysql://root:WACHTWOORD@127.0.0.1/delfzijlrp?charset=utf8mb4"

# ESX / OX instellingen
setr esx:locale "nl"
setr ox:locale "nl"
setr inventory:framework "esx"
setr inventory:slots 50
setr inventory:weight 30000
setr inventory:target true

# Adminvoorbeeld
add_ace group.admin command allow
add_principal identifier.license:VUL_HIER_JE_LICENSE_IDENTIFIER_IN group.admin

# FiveM basis
ensure mapmanager
ensure chat
ensure spawnmanager
ensure sessionmanager
ensure hardcap
ensure baseevents

# Dependencies eerst
ensure oxmysql
ensure ox_lib
ensure ox_target
ensure ox_inventory
ensure ox_doorlock

# ESX Framework
ensure es_extended

# ESX menus
ensure esx_menu_default
ensure esx_menu_dialog
ensure esx_menu_list

# ESX basis
ensure esx_addonaccount
ensure esx_addoninventory
ensure esx_datastore
ensure esx_society
ensure esx_license
ensure esx_billing
ensure esx_status
ensure esx_basicneeds
ensure esx_optionalneeds

# ESX jobresources
ensure esx_policejob
ensure esx_ambulancejob
ensure esx_mechanicjob
ensure esx_taxijob

# Delfzijl RP kernlaag
ensure delfzijlrp_core
ensure delfzijlrp_identity
ensure delfzijlrp_banking2
ensure delfzijlrp_dispatch
ensure delfzijlrp_vehicles

# Delfzijl RP voertuigen en diensten
ensure delfzijlrp_garage
ensure delfzijlrp_anwb
ensure delfzijlrp_taxi

# Delfzijl RP overheid en administratie
ensure delfzijlrp_city
ensure delfzijlrp_mdt_v2
ensure delfzijlrp_court
ensure delfzijlrp_prison
ensure delfzijlrp_fire_rescue

# Delfzijl RP economie en wereldsystemen
ensure delfzijlrp_business_v2
ensure delfzijlrp_groups
ensure delfzijlrp_housing_v2
ensure delfzijlrp_marketplace
ensure delfzijlrp_port
ensure delfzijlrp_public_transport
ensure delfzijlrp_cityhub

# Delfzijl RP UI / telefoon
ensure delfzijlrp_phone_nui
